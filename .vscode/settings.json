{
    "code-runner.executorMap": {
        "cpp": "cd $dir && g++ $fileName freeglut.dll -o $fileNameWithoutExt.exe -I. -L. -lfreeglut -lopengl32 -lglu32 -lgdi32 -lwinmm && .\\$fileNameWithoutExt.exe"
    },
    "code-runner.clearPreviousOutput": true,
    "code-runner.saveFileBeforeRun": true,
    "code-runner.runInTerminal": true
}
